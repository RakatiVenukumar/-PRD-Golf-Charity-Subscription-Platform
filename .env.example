# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Optional: only needed later for admin/server operations
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Admin route access (comma-separated emails)
ADMIN_EMAILS=admin@example.com

# Storage bucket for winner proof screenshots
NEXT_PUBLIC_WINNER_PROOF_BUCKET=winner-proofs

# Payment gateway (Stripe)
STRIPE_SECRET_KEY=sk_test_xxx
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Email notifications (Resend HTTP API)
RESEND_API_KEY=re_xxx
NOTIFICATION_FROM_EMAIL=Digital Heroes <noreply@yourdomain.com>

# Scalability module toggles and locale defaults
NEXT_PUBLIC_DEFAULT_COUNTRY_CODE=US
NEXT_PUBLIC_CAMPAIGNS_ACTIVE=false
NEXT_PUBLIC_ORGANIZATIONS_ACTIVE=false
